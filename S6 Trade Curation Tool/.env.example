# -------------------------------------------------------
# S6 Trade Curation Tool — Environment Variables
# Copy this file to .env.local and fill in your values
# -------------------------------------------------------

# Google Slides API (service account)
# Base64-encode your service account JSON key:
#   cat service-account-key.json | base64 | pbcopy
# Then paste the result below
GOOGLE_SERVICE_ACCOUNT_KEY=

# Optional: Google Drive folder ID to save decks into
# (If blank, decks save to the service account's root Drive)
GOOGLE_DRIVE_FOLDER_ID=

# App settings
NEXT_PUBLIC_APP_NAME="S6 Trade Curation Tool"
